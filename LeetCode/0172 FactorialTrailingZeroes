class Solution {
    public int trailingZeroes(int n) {
       int count = 0;
       if(n<5)
       return 0;
       for(int i =5;i<=n;i++)
       {
        int j =i;
        while(j%5==0 && j!=0)
        {
            count++;
            j/=5;
        }
       
       }
        return count;
    }
}