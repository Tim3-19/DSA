
class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        if(head==null)
        {
            return null;
        }
        int len = 0 ;
        ListNode temp = head;
        while(temp!=null)
        {
            temp=temp.next;
            len++;
        }
        if(n==len)
        {
            head=head.next;
            return head;
        }
       int count = 1;
       temp = head;
       ListNode prev = head;
       temp = temp.next;
       while(temp!=null){
       if(count==(len-n))
       {
        prev.next=temp.next;
        break;

       }
       temp =temp.next;
       prev=prev.next;
       count++;
       }
       return head;
    }
}