class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        if(head==null)
        return null;
        if(head.next==null)
        return head;
        int len=0;
        ListNode temp1 =head;
            
            while(temp1!=null)//To calculate the length of the list
           {len++; 
            temp1=temp1.next;
           
           }
           
        k=k%len;//Actual number of times the list will be rotated
        while(k!=0)
        {
            ListNode temp =head;
            
            while(temp.next.next!=null)
            temp=temp.next;//traversing to second last node
            ListNode newHead = temp.next;//connecting the last node to the initial first 
            newHead.next=head;
            temp.next=null;
            k--;
            head=newHead;

        }
        return head;
    }
}