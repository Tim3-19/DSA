class Solution {
    public int[] plusOne(int[] digits) {
        for(int i =digits.length-1;i>=0;i--)
        {
            if(digits[i]<9)
            {
                digits[i]=digits[i]+1;
                return digits;
            }
            digits[i]=0;//Mkaing the palce with 9 as 0
            

        }
        int ndigits[]=new int[digits.length+1];//If all are 9
         ndigits[0]=1;//only adding a 1 rest will be autofilled
        return ndigits;
    }
}